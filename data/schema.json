{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ecomimagelab/ecommerce-gpt-image-prompts/blob/main/data/schema.json",
  "title": "ecommerce-gpt-image-prompts record v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "slug",
    "model",
    "title",
    "description",
    "prompt",
    "language",
    "mode",
    "category",
    "useCases",
    "styles",
    "backgrounds",
    "platforms",
    "aspectRatios",
    "assetPurpose",
    "inputRequirements",
    "productInvariants",
    "negativePrompt",
    "variants",
    "author",
    "source",
    "license",
    "platformPolicy",
    "review",
    "featured",
    "publishedAt",
    "translations"
  ],
  "properties": {
    "$schema": {"const": "../schema.json"},
    "schemaVersion": {"const": 2},
    "id": {"type": "string", "pattern": "^ec-[0-9]{4,}$"},
    "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "model": {"const": "gpt-image-2"},
    "title": {"type": "string", "minLength": 3, "maxLength": 120},
    "description": {"type": "string", "minLength": 10, "maxLength": 600},
    "prompt": {"type": "string", "minLength": 50},
    "language": {"type": "string", "minLength": 2},
    "mode": {"enum": ["text-to-image", "product-edit"]},
    "category": {"type": "string"},
    "useCases": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string"}
    },
    "styles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {"type": "string"}
    },
    "backgrounds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string"}
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string"}
    },
    "aspectRatios": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[1-9][0-9]*:[1-9][0-9]*$"}
    },
    "assetPurpose": {
      "type": "string"
    },
    "inputRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["referenceImages", "instructions"],
      "properties": {
        "referenceImages": {"type": "integer", "minimum": 0, "maximum": 8},
        "instructions": {"type": "string", "minLength": 10}
      }
    },
    "productInvariants": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 10}
    },
    "negativePrompt": {"type": "string", "minLength": 10},
    "variants": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/variant"}
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "url": {"type": ["string", "null"]}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "url", "permission", "notes", "references"],
      "properties": {
        "type": {"enum": ["original", "community", "licensed", "public-domain"]},
        "url": {"type": ["string", "null"]},
        "permission": {"enum": ["repository-authored", "creator-granted", "compatible-license", "public-domain"]},
        "notes": {"type": "string", "minLength": 10},
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "url"],
            "properties": {
              "type": {"enum": ["visual-research", "official-policy", "original-publication", "license-evidence"]},
              "url": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "license": {"type": "string", "minLength": 1},
    "platformPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "note", "reviewedAt", "sources"],
      "properties": {
        "status": {"enum": ["design-guidance-only", "officially-reviewed"]},
        "note": {"type": "string", "minLength": 10},
        "reviewedAt": {"type": ["string", "null"], "format": "date"},
        "sources": {"type": "array", "items": {"type": "string"}}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "rights", "promptQuality", "previewQuality", "reviewedAt"],
      "properties": {
        "status": {"enum": ["approved", "draft", "rejected", "removed"]},
        "rights": {"enum": ["reviewed", "pending", "disputed"]},
        "promptQuality": {"enum": ["reviewed", "pending"]},
        "previewQuality": {"enum": ["reviewed", "pending"]},
        "reviewedAt": {"type": "string", "format": "date"}
      }
    },
    "featured": {"type": "boolean"},
    "publishedAt": {"type": "string", "format": "date"},
    "translations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "description"],
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "useCase",
        "assetPurpose",
        "platforms",
        "background",
        "aspectRatio",
        "prompt",
        "sample"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "title": {"type": "string", "minLength": 2, "maxLength": 120},
        "useCase": {"type": "string"},
        "assetPurpose": {"type": "string"},
        "platforms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "background": {"type": "string"},
        "aspectRatio": {"type": "string", "pattern": "^[1-9][0-9]*:[1-9][0-9]*$"},
        "prompt": {"type": "string", "minLength": 50},
        "sample": {
          "type": "object",
          "additionalProperties": false,
          "required": ["before", "after", "alt", "license", "provenance"],
          "properties": {
            "before": {"type": ["string", "null"]},
            "after": {"type": "string", "minLength": 1},
            "alt": {"type": "string", "minLength": 3},
            "license": {"type": "string", "minLength": 1},
            "provenance": {"type": "string", "minLength": 10}
          }
        }
      }
    }
  }
}
